# HDDE API — environment (copy to .env; never commit real secrets)
APP_ENV=development
HOST=0.0.0.0
PORT=8090

# SQLite database file (on a Docker volume in prod)
HDDE_DB_PATH=data/hdde.sqlite
HDDE_EXPORTS_DIR=data/exports

# Domain pack (adopted methodology data)
DOMAIN_PACK_PATH=domain_packs/enterprise_hidden_dependency_discovery

# Auth (ADR 0033). Generate a long random SESSION_SECRET. No self-signup.
SESSION_SECRET=change-me-to-a-long-random-string
ALLOW_SIGNUP=false
COOKIE_SECURE=false

# OpenAI red team (ADR 0034). Server-side only; never shipped to the browser.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
LLM_ENABLED=false

# Chokepoints Read API enrichment (ADR 0035) — READ SCOPE ONLY, never read_tainted.
CHOKEPOINTS_API_URL=
CHOKEPOINTS_API_TOKEN=
