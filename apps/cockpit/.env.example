# Cockpit server — environment (copy to .env; never commit real secrets).
# The cockpit is reachable only over Tailscale (ADR 0005/0009); these are server-side only.

# Editorial contradiction / red team (ADR 0039). The key never reaches the browser. Opt-in: leave
# LLM_ENABLED=false (or the key empty) to get a clearly-labelled offline facade instead of a real run.
LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# LLM judge / pré-validation (ADR 0068). The judge runs a REASONING model via the OpenAI Responses API
# (a judge needs precision, not just recall), tuned by reasoning effort (low|medium|high) — NOT
# temperature. The key falls back to OPENAI_API_KEY when empty; the model defaults to gpt-5.6-terra (a
# reasoning model — do NOT set this to gpt-4o, which is not a reasoning model). Effort defaults to medium.
OPENAI_JUDGE_API_KEY=
OPENAI_JUDGE_MODEL=gpt-5.6-terra
OPENAI_JUDGE_EFFORT=medium

# Internal chokepoints exploration (read_tainted scope, Tailnet-only — ADR 0013).
CHOKEPOINTS_API_URL=
CHOKEPOINTS_API_TOKEN=
CHOKEPOINTS_INCLUDE_TAINTED=true
