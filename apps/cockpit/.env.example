# Cockpit server — environment (copy to .env; never commit real secrets).
# The cockpit is reachable only over Tailscale (ADR 0005/0009); these are server-side only.

# Editorial contradiction / red team (ADR 0039). The key never reaches the browser. Opt-in: leave
# LLM_ENABLED=false (or the key empty) to get a clearly-labelled offline facade instead of a real run.
LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Internal chokepoints exploration (read_tainted scope, Tailnet-only — ADR 0013).
CHOKEPOINTS_API_URL=
CHOKEPOINTS_API_TOKEN=
CHOKEPOINTS_INCLUDE_TAINTED=true
