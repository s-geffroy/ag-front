{
  "name": "@ag/cockpit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Internal deployment cockpit (Tailscale-only). React + Vite front end, small editable Express backend over the E-light JSON model.",
  "scripts": {
    "dev": "concurrently -k -n vite,api -c blue,green \"vite\" \"tsx watch server/index.ts\"",
    "dev:api": "tsx watch server/index.ts",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ag/chokepoints": "*",
    "@ag/cvi": "*",
    "@ag/schema": "*",
    "@ag/tokens": "*",
    "@radix-ui/react-dialog": "^1.1.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "express": "^4.21.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.460.0",
    "marked": "^14.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sanitize-html": "^2.17.5",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
