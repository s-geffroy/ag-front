---
import Pill from './Pill.astro';
import CviMeter from './CviMeter.astro';
import { accessLabel, accessTone, formatDate } from '../lib/labels';
interface Props {
  href: string;
  kicker?: string;
  title: string;
  summary: string;
  access?: string;
  date?: Date;
  cvi?: 'bas' | 'modere' | 'eleve' | 'critique';
}
const { href, kicker, title, summary, access, date, cvi } = Astro.props;
const hasSlot = Astro.slots.has('default');
const hasFooter = Boolean(cvi || date || hasSlot);
---

<a href={href} class="card-link group">
  <div class="mb-3 flex items-center justify-between gap-2">
    {kicker ? <span class="label">{kicker}</span> : <span></span>}
    {access ? <Pill tone={accessTone[access]}>{accessLabel[access] ?? access}</Pill> : null}
  </div>
  <h3 class="font-serif text-[1.2rem] font-semibold leading-snug text-ink transition-colors group-hover:text-accent">
    {title}
  </h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{summary}</p>
  {
    hasFooter ? (
      <div class="mt-4 flex flex-wrap items-center justify-between gap-2 border-t border-line pt-3">
        <span class="flex flex-wrap items-center gap-2">
          {cvi ? <CviMeter level={cvi} /> : null}
          <slot />
        </span>
        {date ? <span class="font-mono text-[11px] text-muted">{formatDate(date)}</span> : null}
      </div>
    ) : null
  }
</a>
