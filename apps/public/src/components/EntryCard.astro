---
import Pill from './Pill.astro';
import { accessLabel, accessTone, formatDate } from '../lib/labels';
interface Props {
  href: string;
  kicker?: string;
  title: string;
  summary: string;
  access?: string;
  date?: Date;
}
const { href, kicker, title, summary, access, date } = Astro.props;
---
<a
  href={href}
  class="group flex flex-col rounded-lg border border-line bg-white p-5 transition-colors hover:border-accent/40"
>
  <div class="mb-2 flex items-center gap-2">
    {kicker ? <span class="label">{kicker}</span> : null}
    {access ? <Pill tone={accessTone[access]}>{accessLabel[access] ?? access}</Pill> : null}
  </div>
  <h3 class="font-serif text-lg leading-snug text-ink group-hover:text-accent">{title}</h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{summary}</p>
  <div class="mt-3 flex items-center gap-2">
    <slot />
    {date ? <span class="text-xs text-muted">{formatDate(date)}</span> : null}
  </div>
</a>
