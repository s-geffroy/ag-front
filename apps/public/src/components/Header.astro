---
import { nav } from '../lib/site';
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<header
  class="sticky top-0 z-30 border-t-[3px] border-t-accent border-b border-b-hairline bg-canvas/90 backdrop-blur"
>
  <div
    class="mx-auto flex max-w-content flex-wrap items-center justify-between gap-x-6 gap-y-2 px-5 py-3"
  >
    <a href="/" class="group flex items-baseline gap-2 whitespace-nowrap">
      <span class="font-serif text-lg font-bold tracking-tight text-ink">Applied Geopolitics</span>
      <span class="hidden font-mono text-[10px] uppercase tracking-[0.16em] text-muted sm:inline"
        >Corridors · Flux · Vulnérabilités</span
      >
    </a>
    <nav class="order-3 flex w-full gap-x-5 gap-y-1 overflow-x-auto md:order-2 md:w-auto">
      {
        nav.map((n) => (
          <a
            href={n.href}
            class={`whitespace-nowrap border-b-2 py-0.5 text-sm transition-colors ${
              isActive(n.href)
                ? 'border-accent font-medium text-ink'
                : 'border-transparent text-muted hover:text-ink'
            }`}
          >
            {n.label}
          </a>
        ))
      }
    </nav>
    <div class="order-2 flex items-center gap-2 md:order-3">
      <button
        id="theme-toggle"
        type="button"
        aria-label="Basculer mode jour / nuit"
        title="Mode jour / nuit"
        class="inline-flex h-8 w-8 items-center justify-center rounded-[3px] text-muted hover:bg-subtle hover:text-ink"
      >
        <svg
          class="h-4 w-4 dark:hidden"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <svg
          class="hidden h-4 w-4 dark:block"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
          ></path>
        </svg>
      </button>
      <a href="/contact" class="btn-primary px-3.5 py-1.5"> Échange stratégique </a>
    </div>
  </div>

  <script is:inline>
    (function () {
      var btn = document.getElementById('theme-toggle');
      if (!btn) return;
      btn.addEventListener('click', function () {
        var dark = !document.documentElement.classList.contains('dark');
        document.documentElement.classList.toggle('dark', dark);
        try {
          localStorage.setItem('ag-theme', dark ? 'dark' : 'light');
        } catch (e) {}
      });
    })();
  </script>
</header>
