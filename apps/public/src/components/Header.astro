---
import { nav } from '../lib/site';
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<header class="sticky top-0 z-30 border-b border-line bg-[#fcfcfd]/85 backdrop-blur">
  <div class="mx-auto flex max-w-content flex-wrap items-center justify-between gap-x-6 gap-y-2 px-5 py-3">
    <a href="/" class="font-serif text-lg font-semibold tracking-tight">Applied Geopolitics</a>
    <nav class="order-3 flex w-full gap-x-5 gap-y-1 overflow-x-auto md:order-2 md:w-auto">
      {
        nav.map((n) => (
          <a
            href={n.href}
            class={`whitespace-nowrap py-0.5 text-sm ${isActive(n.href) ? 'text-accent' : 'text-muted hover:text-ink'}`}
          >
            {n.label}
          </a>
        ))
      }
    </nav>
    <a
      href="/contact"
      class="order-2 rounded-md bg-accent px-3.5 py-1.5 text-sm font-medium text-white transition-colors hover:bg-accent/90 md:order-3"
    >
      Échange stratégique
    </a>
  </div>
</header>
