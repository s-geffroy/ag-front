---
/**
 * Chart frame — wraps content in an admiralty-chart border: a faint hairline
 * rectangle with stronger corner crop-marks at each corner. Drawn with
 * `currentColor`, so it follows whatever text colour the caller sets (default
 * navy structural ink) and flips with the theme. Decoration that reads as an
 * instrument, used on the hero and the CTA block.
 */
interface Props {
  class?: string;
  /** Tailwind text-colour class driving the frame (corners + border). */
  tone?: string;
}
const { class: cls = '', tone = 'text-navy' } = Astro.props;
---

<div class={`relative ${cls}`}>
  <div class={`pointer-events-none absolute inset-0 border border-current/15 ${tone}`} aria-hidden="true">
    <span class="absolute left-0 top-0 h-3.5 w-3.5 border-l-2 border-t-2 border-current"></span>
    <span class="absolute right-0 top-0 h-3.5 w-3.5 border-r-2 border-t-2 border-current"></span>
    <span class="absolute bottom-0 left-0 h-3.5 w-3.5 border-b-2 border-l-2 border-current"></span>
    <span class="absolute bottom-0 right-0 h-3.5 w-3.5 border-b-2 border-r-2 border-current"></span>
  </div>
  <slot />
</div>
