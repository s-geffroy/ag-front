---
/**
 * Errata / rectification block — Munich Charter duty 5 (ADR 0037). Rendered on every published
 * artifact: it lists dated corrections, or states that none have been issued, and always offers a
 * way to report an error. Its mere presence is part of the machine-checked compliance (the
 * `corrections` field exists on the schema); its content keeps the record correctable over time.
 */
import { formatDate } from '../lib/labels';
interface Props {
  corrections: { date: Date; note: string }[];
}
const { corrections } = Astro.props;
const sorted = [...corrections].sort((a, b) => b.date.valueOf() - a.date.valueOf());
---

<section class="mt-8 border-t border-line pt-6">
  <div class="label mb-2">Corrections</div>
  {
    sorted.length ? (
      <ul class="space-y-1.5 text-sm text-muted">
        {sorted.map((c) => (
          <li>
            <span class="font-mono text-xs text-ink">{formatDate(c.date)}</span> — {c.note}
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-sm text-muted">Aucune correction à ce jour.</p>
    )
  }
  <p class="mt-3 text-xs text-muted">
    Une inexactitude ?{' '}
    <a href="/contact" class="text-accent underline underline-offset-2">Signaler une erreur</a> — nous
    rectifions et datons la correction.
  </p>
</section>
