---
/**
 * CVI vulnerability meter — the site's signature instrument.
 * A framed, calibrated gauge: four graduated cells inside a hairline frame that
 * fill up to the scored level, each cell carrying its own ramp colour, plus a
 * mono read of the band. Reused on cards, fiche headers and the method page so
 * vulnerability is always read the same way — and the gauge doubles as the map
 * legend.
 */
type Level = 'bas' | 'modere' | 'eleve' | 'critique';
interface Props {
  level: Level;
  showLabel?: boolean;
  class?: string;
}
const { level, showLabel = true, class: cls = '' } = Astro.props;

const order: Level[] = ['bas', 'modere', 'eleve', 'critique'];
const idx = order.indexOf(level);
const shortLabel: Record<Level, string> = {
  bas: 'Basse',
  modere: 'Modérée',
  eleve: 'Élevée',
  critique: 'Critique',
};
// Each segment owns a ramp colour; segments up to the level light up.
const segVar = ['--cvi-1', '--cvi-2', '--cvi-3', '--cvi-4'];
const labelVar = segVar[idx];
---

<span
  class={`inline-flex items-center gap-2 ${cls}`}
  role="img"
  aria-label={`Vulnérabilité ${shortLabel[level].toLowerCase()}`}
  title={`Vulnérabilité ${shortLabel[level].toLowerCase()}`}
>
  <span
    class="flex items-stretch overflow-hidden rounded-[1px] border border-hairline"
    aria-hidden="true"
  >
    {
      segVar.map((sv, i) => (
        <span
          class="h-[11px] w-[14px] border-r border-hairline last:border-r-0"
          style={
            i <= idx
              ? `background: rgb(var(${sv}))`
              : 'background: rgb(var(--subtle))'
          }
        />
      ))
    }
  </span>
  {
    showLabel ? (
      <span class="inline-flex items-baseline gap-1.5" aria-hidden="true">
        <span
          class="font-mono text-[10px] font-semibold uppercase tracking-[0.1em]"
          style={`color: rgb(var(${labelVar}))`}
        >
          {shortLabel[level]}
        </span>
        <span class="font-mono text-[10px] tabular-nums text-muted">{idx + 1}/4</span>
      </span>
    ) : null
  }
</span>
