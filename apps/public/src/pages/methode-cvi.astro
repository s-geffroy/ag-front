---
import { cviDimensions, cviDimensionKeys } from '@ag/cvi';
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import Pill from '../components/Pill.astro';

const scales = [
  { offer: 'Public / Basic', scale: 'Diagnostic qualitatif', detail: 'bas · modéré · élevé · critique' },
  { offer: 'Standard', scale: 'Score 0–5 par dimension', detail: '+ niveau global qualitatif' },
  { offer: 'Premium', scale: 'Score agrégé 0–100', detail: 'uniquement si la méthodologie est documentée' },
];
---

<Base
  title="Méthode CVI"
  description="Le Corridor Vulnerability Index : huit dimensions pour évaluer la vulnérabilité d’un corridor, sans illusion de précision."
>
  <Section width="prose" class="py-14">
    <h1 class="text-3xl">Méthode CVI</h1>
    <p class="prose-ag mt-3">
      Le <strong>Corridor Vulnerability Index</strong> évalue la vulnérabilité d’un corridor de façon
      structurée, <strong>sans créer d’illusion de précision mécanique</strong>. Il distingue
      notamment la <em>menace</em> (un acteur ou un événement) de la <em>capacité réelle</em> de
      perturbation.
    </p>
  </Section>

  <Section class="pb-6">
    <h2 class="mb-4 text-2xl">Les huit dimensions</h2>
    <div class="grid gap-4 md:grid-cols-2">
      {
        cviDimensionKeys.map((k, i) => (
          <div class="rounded-lg border border-line bg-surface p-5">
            <div class="flex items-baseline gap-2">
              <span class="font-serif text-sm text-accent">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="font-serif text-lg">{cviDimensions[k].label}</h3>
            </div>
            <p class="mt-1.5 text-sm text-muted">{cviDimensions[k].question}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <Section width="prose" class="py-10">
    <h2 class="text-2xl">Une échelle progressive</h2>
    <p class="prose-ag mt-3">
      L’échelle dépend de l’offre. Règle dure : <strong>pas de score global 0–100 sans documentation
      méthodologique</strong>.
    </p>
    <div class="mt-5 space-y-3">
      {
        scales.map((s) => (
          <div class="flex flex-wrap items-baseline justify-between gap-2 rounded-lg border border-line bg-surface p-4">
            <div>
              <div class="font-medium text-ink">{s.scale}</div>
              <div class="text-sm text-muted">{s.detail}</div>
            </div>
            <Pill tone="accent">{s.offer}</Pill>
          </div>
        ))
      }
    </div>
    <p class="prose-ag mt-6 text-sm text-muted">
      Chaque score affiche ses sources, sa date de mise à jour, son niveau de confiance et ses
      incertitudes. Le CVI ne remplace jamais le jugement interne du client.
    </p>
  </Section>
</Base>
