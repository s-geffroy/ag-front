---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import EntryCard from '../components/EntryCard.astro';
import Pill from '../components/Pill.astro';
import { doctrineChain, offers, site } from '../lib/site';
import { cviLevelLabel } from '../lib/labels';

const atlas = (await getCollection('atlas')).slice(0, 3);
const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const dossiers = (await getCollection('dossiers')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const lead = dossiers[0];
---

<Base>
  <!-- Hero -->
  <Section class="pb-14 pt-16 md:pt-24">
    <p class="label">{site.baseline}</p>
    <h1 class="mt-4 max-w-3xl text-4xl leading-[1.1] md:text-5xl">
      Comprendre les flux de puissance. Révéler les dépendances critiques. Anticiper les
      vulnérabilités géopolitiques.
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-muted">
      Applied Geopolitics aide les organisations exposées aux corridors stratégiques à transformer
      l’analyse géopolitique en <strong class="text-ink">décisions de résilience</strong>.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      {
        lead ? (
          <a
            href={`/dossiers/${lead.slug}`}
            class="rounded-md bg-accent px-5 py-2.5 text-sm font-medium text-white hover:bg-accent/90"
          >
            Lire le dossier Mer Rouge / Suez
          </a>
        ) : null
      }
      <a
        href="/atlas"
        class="rounded-md border border-line bg-white px-5 py-2.5 text-sm font-medium hover:border-accent/40"
      >
        Découvrir l’Atlas
      </a>
    </div>
  </Section>

  <!-- Doctrine chain -->
  <Section class="border-y border-line bg-white py-10">
    <p class="label mb-4">La chaîne d’analyse</p>
    <ol class="flex flex-wrap items-center gap-x-2 gap-y-2">
      {
        doctrineChain.map((step, i) => (
          <li class="flex items-center gap-2">
            <span class="font-serif text-base text-ink">{step}</span>
            {i < doctrineChain.length - 1 ? <span class="text-accent">→</span> : null}
          </li>
        ))
      }
    </ol>
  </Section>

  <!-- Problème / approche -->
  <Section class="grid gap-10 py-16 md:grid-cols-2">
    <div>
      <h2 class="text-2xl">Le problème</h2>
      <p class="prose-ag mt-3">
        La plupart des organisations dépendent de corridors qu’elles comprennent mal : un détroit, un
        hub portuaire, un câble, une route énergétique. Tant que tout circule, la dépendance reste
        invisible. Elle ne le reste plus au premier choc.
      </p>
    </div>
    <div>
      <h2 class="text-2xl">L’approche</h2>
      <p class="prose-ag mt-3">
        Nous traitons chaque corridor comme un système : nœuds, flux, acteurs de contrôle,
        vulnérabilités, seuils de bascule. La méthode <strong>CVI</strong> rend cette vulnérabilité
        lisible — du diagnostic qualitatif au score par dimension.
      </p>
    </div>
  </Section>

  <!-- Atlas -->
  <Section class="py-6">
    <div class="mb-5 flex items-end justify-between">
      <h2 class="text-2xl">Atlas des corridors</h2>
      <a href="/atlas" class="text-sm text-accent hover:underline">Tout l’Atlas →</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {
        atlas.map((f) => (
          <EntryCard
            href={`/atlas/${f.slug}`}
            kicker="Fiche Atlas"
            title={f.data.title}
            summary={f.data.verdict}
            access={f.data.access}
          >
            {f.data.cvi_level ? <Pill>{cviLevelLabel[f.data.cvi_level]}</Pill> : null}
          </EntryCard>
        ))
      }
    </div>
  </Section>

  <!-- Notes -->
  <Section class="py-12">
    <div class="mb-5 flex items-end justify-between">
      <h2 class="text-2xl">Notes récentes</h2>
      <a href="/notes" class="text-sm text-accent hover:underline">Toutes les notes →</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {
        notes.map((n) => (
          <EntryCard
            href={`/notes/${n.slug}`}
            kicker="Note"
            title={n.data.title}
            summary={n.data.summary}
            date={n.data.date}
          />
        ))
      }
    </div>
  </Section>

  <!-- Offres -->
  <Section class="border-t border-line py-16">
    <div class="mb-2 flex items-end justify-between">
      <h2 class="text-2xl">Offres</h2>
      <a href="/offres" class="text-sm text-accent hover:underline">Comparer les offres →</a>
    </div>
    <p class="mb-6 text-muted">Basic informe. Standard surveille. Premium aide à arbitrer.</p>
    <div class="grid gap-4 md:grid-cols-3">
      {
        offers.map((o) => (
          <div class={`rounded-lg border p-5 ${o.featured ? 'border-accent/40 bg-white' : 'border-line bg-white'}`}>
            <div class="flex items-baseline justify-between">
              <h3 class="font-serif text-xl">{o.name}</h3>
              <span class="label">{o.promise}</span>
            </div>
            <p class="mt-2 text-sm text-muted">{o.tagline}</p>
            <p class="mt-3 text-sm font-medium text-ink">{o.price}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- CTA -->
  <Section class="pb-20">
    <div class="rounded-xl border border-line bg-accent/[0.04] p-8 text-center">
      <h2 class="text-2xl">Un corridor vous expose ?</h2>
      <p class="mx-auto mt-2 max-w-xl text-muted">
        Nous échangeons d’abord sur un problème réel — pas sur une offre. Vingt minutes pour
        identifier vos angles morts opérationnels.
      </p>
      <a
        href="/contact"
        class="mt-5 inline-block rounded-md bg-accent px-5 py-2.5 text-sm font-medium text-white hover:bg-accent/90"
      >
        Demander un échange stratégique
      </a>
    </div>
  </Section>
</Base>
