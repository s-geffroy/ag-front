---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import EntryCard from '../components/EntryCard.astro';
import Pill from '../components/Pill.astro';
import CorridorChain from '../components/CorridorChain.astro';
import ChartFrame from '../components/ChartFrame.astro';
import { doctrineChain, offers } from '../lib/site';
import { accessLabel, accessTone, formatDate } from '../lib/labels';

const atlas = (await getCollection('atlas'))
  .sort((a, b) => a.data.priority.localeCompare(b.data.priority))
  .slice(0, 3);
const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const dossiers = (await getCollection('dossiers')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const lead = dossiers[0];
---

<Base>
  <!-- Hero — the thesis, set as a framed chart title block -->
  <Section class="bg-graticule pb-12 pt-14 md:pt-20">
    <ChartFrame tone="text-navy" class="bg-canvas/85 px-6 py-8 md:px-10 md:py-12">
      <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
        <p class="eyebrow">Note stratégique · Corridors &amp; flux de puissance</p>
        <span class="label">Relevé · Édition 2026</span>
      </div>
      <h1 class="mt-5 max-w-4xl font-serif text-display font-bold text-balance">
        Comprendre les flux de puissance, révéler les dépendances critiques, anticiper les
        vulnérabilités géopolitiques.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted">
        Applied Geopolitics aide les organisations exposées aux corridors stratégiques à transformer
        l’analyse géopolitique en <strong class="font-semibold text-ink">décisions de résilience</strong>.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        {lead ? <a href={`/dossiers/${lead.slug}`} class="btn-primary">Lire le dossier Mer Rouge / Suez</a> : null}
        <a href="/atlas" class="btn-ghost">Découvrir l’Atlas</a>
      </div>
    </ChartFrame>
  </Section>

  <!-- Doctrine chain as an instrumented corridor -->
  <Section class="bg-graticule border-y border-line bg-surface py-9">
    <p class="label mb-5">La chaîne d’analyse</p>
    <CorridorChain steps={doctrineChain} />
  </Section>

  <!-- Lead briefing: the founding dossier -->
  {
    lead ? (
      <Section class="pt-16">
        <a
          href={`/dossiers/${lead.slug}`}
          class="group block border-l-2 border-accent bg-surface p-6 transition-colors hover:bg-subtle md:p-8"
        >
          <div class="flex flex-wrap items-center gap-3">
            <span class="eyebrow">À la une · Dossier</span>
            <Pill tone={accessTone[lead.data.access]}>{accessLabel[lead.data.access]}</Pill>
          </div>
          <h2 class="mt-4 max-w-3xl font-serif text-title font-semibold text-ink group-hover:text-accent">
            {lead.data.title}
          </h2>
          <p class="verdict mt-4 max-w-3xl">{lead.data.strategic_question}</p>
          <p class="mt-5 font-mono text-[11px] uppercase tracking-[0.08em] text-muted">
            {formatDate(lead.data.date)} · Résumé public · Dossier complet réservé aux offres
          </p>
        </a>
      </Section>
    ) : null
  }

  <!-- Problème / approche -->
  <Section class="grid gap-x-12 gap-y-8 py-16 md:grid-cols-2">
    <div>
      <div class="section-rule"><span class="label">Le problème</span></div>
      <p class="prose-ag">
        La plupart des organisations dépendent de corridors qu’elles comprennent mal : un détroit, un
        hub portuaire, un câble, une route énergétique. Tant que tout circule, la dépendance reste
        invisible. Elle ne le reste plus au premier choc.
      </p>
    </div>
    <div>
      <div class="section-rule"><span class="label">L’approche</span></div>
      <p class="prose-ag">
        Nous traitons chaque corridor comme un système : nœuds, flux, acteurs de contrôle,
        vulnérabilités, seuils de bascule. La méthode <strong>CVI</strong> rend cette vulnérabilité
        lisible — du diagnostic qualitatif au score par dimension.
      </p>
    </div>
  </Section>

  <!-- Atlas -->
  <Section class="py-6">
    <div class="section-rule">
      <span class="label">Atlas des corridors</span>
      <a href="/atlas" class="ml-auto text-sm text-accent hover:underline">Tout l’Atlas →</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {
        atlas.map((f) => (
          <EntryCard
            href={`/atlas/${f.slug}`}
            kicker="Fiche Atlas"
            title={f.data.title}
            summary={f.data.verdict}
            access={f.data.access}
            cvi={f.data.cvi_level}
          />
        ))
      }
    </div>
  </Section>

  <!-- Notes -->
  <Section class="py-14">
    <div class="section-rule">
      <span class="label">Notes récentes</span>
      <a href="/notes" class="ml-auto text-sm text-accent hover:underline">Toutes les notes →</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {
        notes.map((n) => (
          <EntryCard
            href={`/notes/${n.slug}`}
            kicker="Note"
            title={n.data.title}
            summary={n.data.summary}
            date={n.data.date}
          />
        ))
      }
    </div>
  </Section>

  <!-- Offres — the capability ladder -->
  <Section class="py-6">
    <div class="section-rule">
      <span class="label">Offres</span>
      <a href="/offres" class="ml-auto text-sm text-accent hover:underline">Comparer les offres →</a>
    </div>
    <p class="mb-6 text-muted">
      <strong class="text-ink">Basic</strong> informe. <strong class="text-ink">Standard</strong>
      surveille. <strong class="text-ink">Premium</strong> aide à arbitrer.
    </p>
    <div class="grid gap-4 md:grid-cols-3">
      {
        offers.map((o, i) => (
          <div
            class={`flex flex-col border bg-surface p-5 ${o.featured ? 'border-accent' : 'border-line'}`}
          >
            <div class="flex items-baseline justify-between gap-2">
              <h3 class="font-serif text-xl font-semibold">{o.name}</h3>
              <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-accent">
                {String(i + 1).padStart(2, '0')} · {o.promise}
              </span>
            </div>
            <p class="mt-2 flex-1 text-sm text-muted">{o.tagline}</p>
            <p class="mt-4 font-mono text-sm font-medium text-ink">{o.price}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- CTA -->
  <Section class="pb-24 pt-16">
    <ChartFrame tone="text-navy" class="bg-surface p-8 text-center md:p-12">
      <p class="eyebrow justify-center">Échange stratégique</p>
      <h2 class="mt-4 font-serif text-title font-semibold">Un corridor vous expose ?</h2>
      <p class="mx-auto mt-3 max-w-xl text-muted">
        Nous échangeons d’abord sur un problème réel — pas sur une offre. Vingt minutes pour
        identifier vos angles morts opérationnels.
      </p>
      <a href="/contact" class="btn-primary mt-6">Demander un échange stratégique</a>
    </ChartFrame>
  </Section>
</Base>
