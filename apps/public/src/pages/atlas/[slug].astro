---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Section from '../../components/Section.astro';
import Pill from '../../components/Pill.astro';
import Sources from '../../components/Sources.astro';
import {
  accessLabel,
  accessTone,
  confidenceLabel,
  cviLevelLabel,
  cviLevelTone,
  familyLabel,
  formatDate,
} from '../../lib/labels';

export async function getStaticPaths() {
  const fiches = await getCollection('atlas');
  return fiches.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<'atlas'>;
}
const { entry } = Astro.props;
const d = entry.data;
const { Content } = await entry.render();
---

<Base title={d.title} description={d.verdict} type="article">
  <Section width="prose" class="py-12">
    <a href="/atlas" class="text-sm text-accent hover:underline">← Atlas</a>
    <div class="mt-4 flex flex-wrap gap-2">
      <Pill tone="neutral">{familyLabel[d.family] ?? d.family}</Pill>
      <Pill tone={accessTone[d.access]}>{accessLabel[d.access]}</Pill>
      {d.cvi_level ? <Pill tone={cviLevelTone[d.cvi_level]}>{cviLevelLabel[d.cvi_level]}</Pill> : null}
    </div>
    <h1 class="mt-4 text-3xl">{d.title}</h1>
    <p class="mt-4 border-l-2 border-accent/50 pl-4 font-serif text-lg leading-snug text-ink">
      {d.verdict}
    </p>
    <div class="mt-3 text-xs text-muted">
      Mis à jour le {formatDate(d.updated)} · {confidenceLabel[d.confidence]}
    </div>
    <article class="prose-ag mt-8"><Content /></article>
    <Sources sources={d.sources} />
  </Section>
</Base>
