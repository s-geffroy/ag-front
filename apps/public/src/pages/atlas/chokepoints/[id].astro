---
import Base from '../../../layouts/Base.astro';
import Section from '../../../components/Section.astro';
import Pill from '../../../components/Pill.astro';
import { humanize, priorityTone } from '../../../lib/labels';
import { loadChokepoints, loadChokepointDetail, type AtlasChokepoint } from '../../../lib/atlas-data';

export async function getStaticPaths() {
  const { items } = await loadChokepoints();
  return items.map((summary) => ({ params: { id: summary.id }, props: { summary } }));
}

interface Props {
  summary: AtlasChokepoint;
}
const { summary } = Astro.props;
const detail = await loadChokepointDetail(summary.id);
---

<Base title={summary.name} description={`Chokepoint — ${humanize(summary.family)}`} type="article">
  <Section width="prose" class="py-12">
    <a href="/atlas" class="font-mono text-[11px] uppercase tracking-[0.1em] text-muted hover:text-accent">
      ← Atlas
    </a>
    <div class="mt-5 flex flex-wrap items-center gap-2">
      <Pill tone="navy">{humanize(summary.family) || 'Chokepoint'}</Pill>
      {summary.priority ? <Pill tone={priorityTone[summary.priority] ?? 'neutral'}>{summary.priority}</Pill> : null}
      {summary.region ? <Pill tone="neutral">{summary.region}</Pill> : null}
    </div>
    <h1 class="mt-5 font-serif text-title font-bold">{summary.name}</h1>
    {
      summary.attributions.length ? (
        <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.08em] text-muted">
          Attribution : {summary.attributions.join(' · ')}
        </p>
      ) : null
    }

    {
      detail ? (
        <div class="mt-10 space-y-10">
          {detail.flows.length ? (
            <section>
              <div class="section-rule"><span class="label">Flux</span></div>
              <ul class="space-y-2.5 text-sm">
                {detail.flows.map((f) => (
                  <li>
                    <span class="font-medium">{humanize(f.flow_type)}</span>
                    {f.directionality ? ` · ${f.directionality}` : ''}
                    {f.importance_score != null ? ` · importance ${f.importance_score}` : ''}
                    {/* A volume never appears bare: `value_status` grades the evidence and
                        `method_note` states what the figure excludes. A `qualitative_scored` flow
                        carries no volume at all, by design — omit, never fabricate. */}
                    {f.estimated_volume != null ? (
                      <div class="text-muted">
                        {f.estimated_volume} {f.volume_unit ?? ''}
                        {f.volume_year ? ` (${f.volume_year})` : ''}
                        {f.value_status ? ` · ${humanize(f.value_status)}` : ''}
                      </div>
                    ) : null}
                    {f.method_note ? <div class="text-xs italic text-muted">{f.method_note}</div> : null}
                  </li>
                ))}
              </ul>
            </section>
          ) : null}

          {detail.metrics.length ? (
            <section>
              <div class="section-rule"><span class="label">Métriques de référence</span></div>
              <p class="mb-2 text-xs text-muted">
                Une métrique n'est pas un flux : un <em>stock</em> est un solde à une date, une
                <em> capacité</em> un maximum potentiel. Ni l'un ni l'autre ne se compare à un volume
                réellement écoulé.
              </p>
              <ul class="space-y-2 text-sm">
                {detail.metrics.map((m) => (
                  <li>
                    <span class="font-medium">{m.metric_label ?? humanize(m.metric_key)}</span>
                    {m.metric_kind ? ` · ${humanize(m.metric_kind)}` : ''}
                    <div class="text-muted">
                      {m.value != null ? `${m.value} ${m.unit ?? ''}` : '—'}
                      {m.period ? ` · ${m.period}` : ''}
                    </div>
                    {m.notes ? <div class="text-xs italic text-muted">{m.notes}</div> : null}
                  </li>
                ))}
              </ul>
            </section>
          ) : null}

          {detail.risks.length ? (
            <section>
              <div class="section-rule"><span class="label">Risques</span></div>
              <ul class="space-y-1.5 text-sm">
                {detail.risks.map((r) => (
                  <li>
                    <span class="font-medium">{humanize(r.risk_type)}</span>
                    {r.risk_severity ? ` · ${humanize(r.risk_severity)}` : ''}
                    {r.assessment_status ? ` · ${humanize(r.assessment_status)}` : ''}
                    {r.impact_score != null ? ` · impact ${r.impact_score}` : ''}
                  </li>
                ))}
              </ul>
            </section>
          ) : null}

          {detail.alternatives.length ? (
            <section>
              <div class="section-rule"><span class="label">Alternatives / bypass</span></div>
              <ul class="space-y-2 text-sm">
                {detail.alternatives.map((a) => (
                  <li>
                    <span class="font-medium">{a.description}</span>
                    {a.feasibility ? ` — faisabilité : ${humanize(a.feasibility)}` : ''}
                    {a.capacity_penalty ? ` · pénalité de capacité : ${humanize(String(a.capacity_penalty))}` : ''}
                    {a.validation_status ? ` · ${humanize(a.validation_status)}` : ''}
                    {a.substitution_note ? <div class="text-muted">{a.substitution_note}</div> : null}
                  </li>
                ))}
              </ul>
            </section>
          ) : null}

          {detail.episodes.length ? (
            <section>
              <div class="section-rule"><span class="label">Épisodes de perturbation</span></div>
              <ul class="space-y-1.5 text-sm">
                {detail.episodes.map((e) => (
                  <li>
                    {e.name}
                    {e.started_on ? ` · ${e.started_on}${e.ended_on ? ` → ${e.ended_on}` : ''}` : ''}
                    {e.severity ? ` · ${humanize(e.severity)}` : ''}
                    {e.status ? ` · ${humanize(e.status)}` : ''}
                  </li>
                ))}
              </ul>
            </section>
          ) : null}
        </div>
      ) : (
        <p class="mt-8 text-sm text-muted">Détail indisponible pour ce nœud.</p>
      )
    }

    <div class="mt-12 border border-line bg-subtle p-4 text-xs leading-relaxed text-muted">
      Données canoniques issues de la base <strong>chokepoints</strong> (lecture seule).{' '}
      {detail?.geometry_disclaimer ??
        'Géométrie schématique, sans valeur navigationnelle ou juridique.'}{' '}
      Les résultats analytiques dérivés sont des candidats en attente de validation humaine et ne
      constituent ni une prédiction ni un conseil engageant.
    </div>
  </Section>
</Base>
