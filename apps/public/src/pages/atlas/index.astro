---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Section from '../../components/Section.astro';
import EntryCard from '../../components/EntryCard.astro';
import Pill from '../../components/Pill.astro';
import { familyLabel, humanize, priorityTone } from '../../lib/labels';
import { loadChokepoints } from '../../lib/atlas-data';

const fiches = (await getCollection('atlas')).sort((a, b) =>
  a.data.priority.localeCompare(b.data.priority),
);

const chokepoints = await loadChokepoints();
const nodes = chokepoints.items
  .slice()
  .sort(
    (a, b) =>
      (a.priority ?? 'P9').localeCompare(b.priority ?? 'P9') || a.name.localeCompare(b.name),
  );
---

<Base
  title="Atlas des corridors"
  description="L’Atlas stratégique des corridors : fiches structurées et base de données des chokepoints."
>
  <Section class="py-14">
    <p class="eyebrow">Atlas stratégique</p>
    <h1 class="mt-4 max-w-3xl font-serif text-title font-bold">
      Atlas stratégique des corridors
    </h1>
    <p class="prose-ag mt-4 max-w-prose">
      L’Atlas est une grille de lecture et une base de fiches comparables. Chaque fiche commence par un
      verdict stratégique, explicite les flux et propose des seuils d’alerte. Le scoring CVI 0–5 par
      dimension est réservé aux offres payantes.
    </p>

    <div class="section-rule mt-12"><span class="label">Fiches</span></div>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        fiches.map((f) => (
          <EntryCard
            href={`/atlas/${f.slug}`}
            kicker={familyLabel[f.data.family] ?? f.data.family}
            title={f.data.title}
            summary={f.data.verdict}
            access={f.data.access}
            cvi={f.data.cvi_level}
          />
        ))
      }
    </div>

    {
      chokepoints.ok && nodes.length ? (
        <div class="mt-16">
          <div class="section-rule">
            <span class="label">Chokepoints prioritaires · P0</span>
            <a href="/atlas/carte" class="ml-auto text-sm text-accent hover:underline">
              Carte interactive →
            </a>
          </div>
          <p class="-mt-2 mb-5 max-w-prose text-sm text-muted">
            Cœur stratégique extrait de la base de données des chokepoints (plusieurs centaines de nœuds
            P0–P3, lecture seule). {chokepoints.attributionNotice ??
              'Géométrie schématique, sans valeur navigationnelle ou juridique.'}
          </p>
          <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            {nodes.map((c) => (
              <EntryCard
                href={`/atlas/chokepoints/${c.id}`}
                kicker={humanize(c.family) || 'Chokepoint'}
                title={c.name}
                summary={c.region ? `Région : ${c.region}` : 'Nœud canonique de la base chokepoints.'}
              >
                {c.priority ? <Pill tone={priorityTone[c.priority] ?? 'neutral'}>{c.priority}</Pill> : null}
                {c.attributions.length ? <Pill tone="neutral">Attribution requise</Pill> : null}
              </EntryCard>
            ))}
          </div>
        </div>
      ) : null
    }
  </Section>
</Base>
