---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
---

<Base title="Page introuvable">
  <Section class="py-28 text-center">
    <p class="eyebrow justify-center">Erreur 404</p>
    <h1 class="mt-4 font-serif text-title font-bold">Cette page n’existe pas</h1>
    <p class="mt-3 text-muted">Le corridor que vous cherchez a peut-être été dérouté.</p>
    <a href="/" class="btn-primary mt-7">Retour à l’accueil</a>
  </Section>
</Base>
