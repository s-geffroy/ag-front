---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
---

<Base title="Page introuvable">
  <Section class="py-24 text-center">
    <p class="label">Erreur 404</p>
    <h1 class="mt-3 text-3xl">Cette page n’existe pas</h1>
    <p class="mt-3 text-muted">Le corridor que vous cherchez a peut-être été dérouté.</p>
    <a
      href="/"
      class="mt-6 inline-block rounded-md bg-accent px-5 py-2.5 text-sm font-medium text-white hover:bg-accent/90"
    >
      Retour à l’accueil
    </a>
  </Section>
</Base>
