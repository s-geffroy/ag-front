---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import { site } from '../lib/site';

const fieldClass =
  'mt-1 w-full rounded-[2px] border border-hairline bg-surface px-3 py-2 text-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/25';
---

<Base
  title="Contact"
  description="Demander un échange stratégique, un pilote Premium, ou transmettre une critique."
>
  <Section width="prose" class="py-14">
    <p class="eyebrow">Contact</p>
    <h1 class="mt-4 font-serif text-title font-bold">Échange stratégique</h1>
    <p class="prose-ag mt-4">
      Nous échangeons d’abord sur un problème réel — pas sur une offre. Vingt minutes pour identifier
      vos angles morts opérationnels sur un corridor qui vous expose.
    </p>

    <form id="contact-form" class="mt-8 space-y-4">
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block text-sm">
          <span class="font-medium">Nom</span>
          <input name="name" required class={fieldClass} />
        </label>
        <label class="block text-sm">
          <span class="font-medium">Organisation</span>
          <input name="org" class={fieldClass} />
        </label>
      </div>
      <label class="block text-sm">
        <span class="font-medium">Email</span>
        <input type="email" name="email" required class={fieldClass} />
      </label>
      <label class="block text-sm">
        <span class="font-medium">Sujet</span>
        <select name="subject" class={fieldClass}>
          <option value="echange">Échange stratégique</option>
          <option value="pilote">Pilote Premium</option>
          <option value="critique">Critique d’un dossier</option>
          <option value="presse">Presse / partenariat</option>
        </select>
      </label>
      <label class="block text-sm">
        <span class="font-medium">Message</span>
        <textarea name="message" rows="5" class={fieldClass}></textarea>
      </label>
      <!-- honeypot anti-spam : laissé vide par les humains -->
      <input
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
        class="hidden"
      />
      <button type="submit" class="btn-primary"> Envoyer </button>
      <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>
      <p class="text-xs text-muted">
        Vos informations servent uniquement à répondre à votre demande. Vous pouvez aussi écrire
        directement à <a href={`mailto:${site.email}`} class="text-accent underline">{site.email}</a>.
      </p>
    </form>
  </Section>

  <script is:inline define:vars={{ email: site.email }}>
    const form = document.getElementById('contact-form');
    const statusEl = document.getElementById('form-status');
    const subjects = {
      echange: 'Échange stratégique',
      pilote: 'Pilote Premium',
      critique: 'Critique d’un dossier',
      presse: 'Presse / partenariat',
    };

    const presel = new URLSearchParams(location.search).get('sujet');
    if (presel) {
      const sel = form?.querySelector('select[name="subject"]');
      if (sel) sel.value = presel;
    }

    function mailtoFallback(f) {
      const subject = subjects[f.get('subject')] || 'Contact';
      const body =
        `Nom : ${f.get('name') || ''}\n` +
        `Organisation : ${f.get('org') || ''}\n` +
        `Email : ${f.get('email') || ''}\n\n` +
        `${f.get('message') || ''}`;
      location.href = `mailto:${email}?subject=${encodeURIComponent('[AG] ' + subject)}&body=${encodeURIComponent(body)}`;
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = new FormData(form);
      const btn = form.querySelector('button[type="submit"]');
      const payload = {
        name: String(f.get('name') || ''),
        email: String(f.get('email') || ''),
        organization: String(f.get('org') || ''),
        subject: String(f.get('subject') || 'echange'),
        message: String(f.get('message') || ''),
        website: String(f.get('website') || ''),
      };
      if (statusEl) {
        statusEl.textContent = 'Envoi…';
        statusEl.className = 'text-sm text-muted';
      }
      if (btn) btn.disabled = true;
      try {
        const res = await fetch('/api/lead', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error('status ' + res.status);
        form.reset();
        if (statusEl) {
          statusEl.textContent =
            'Merci, votre message a bien été reçu. Nous revenons vers vous rapidement.';
          statusEl.className = 'text-sm text-status-on_track';
        }
      } catch (err) {
        if (statusEl) {
          statusEl.textContent = 'L’envoi a échoué — ouverture de votre client mail…';
          statusEl.className = 'text-sm text-status-at_risk';
        }
        mailtoFallback(f);
      } finally {
        if (btn) btn.disabled = false;
      }
    });
  </script>
</Base>
