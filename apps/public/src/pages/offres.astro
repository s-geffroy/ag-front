---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import { offers } from '../lib/site';
---

<Base
  title="Offres"
  description="Basic informe. Standard surveille. Premium aide à arbitrer. Trois offres pour transformer l’analyse des corridors en décisions."
>
  <Section class="py-14">
    <p class="eyebrow">Offres</p>
    <h1 class="mt-4 font-serif text-title font-bold">Trois niveaux de lecture</h1>
    <p class="mt-3 max-w-prose text-lg text-muted">
      <strong class="text-ink">Basic</strong> informe. <strong class="text-ink">Standard</strong>
      surveille. <strong class="text-ink">Premium</strong> aide à arbitrer.
    </p>

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        offers.map((o, i) => (
          <div
            class={`flex flex-col border bg-surface ${o.featured ? 'border-accent' : 'border-line'}`}
          >
            {o.featured ? (
              <div class="bg-accent px-6 py-1.5 text-center font-mono text-[10px] uppercase tracking-[0.16em] text-white">
                Recommandé au lancement
              </div>
            ) : null}
            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-baseline justify-between gap-2">
                <h2 class="font-serif text-2xl font-bold">{o.name}</h2>
                <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-accent">
                  {String(i + 1).padStart(2, '0')} · {o.promise}
                </span>
              </div>
              <p class="mt-2 text-sm text-muted">{o.tagline}</p>
              <p class="mt-4 font-mono text-lg font-semibold text-ink">{o.price}</p>

              <ul class="mt-5 flex-1 space-y-1.5 text-sm">
                {o.includes.map((inc) => (
                  <li class="flex gap-2">
                    <span class="mt-0.5 text-status-on_track" aria-hidden="true">
                      ✓
                    </span>
                    <span class={inc.trimEnd().endsWith(':') ? 'font-medium text-ink' : 'text-ink/90'}>{inc}</span>
                  </li>
                ))}
                {o.excludes.map((exc) => (
                  <li class="flex gap-2 text-muted">
                    <span class="mt-0.5" aria-hidden="true">
                      —
                    </span>
                    <span>{exc}</span>
                  </li>
                ))}
              </ul>

              <a
                href={o.cta.href}
                class={`mt-6 text-center ${o.featured ? 'btn-primary' : 'btn-ghost'}`}
              >
                {o.cta.label}
              </a>
            </div>
          </div>
        ))
      }
    </div>

    <p class="mt-8 max-w-prose text-sm text-muted">
      Plafonds du pilote Premium : 1 corridor principal, 1 comparatif optionnel, 2–3 flux, 3–5 signaux
      suivis, 1 restitution. Au lancement, les offres Basic et Standard ouvrent progressivement à mesure
      que l’Atlas et l’historique se constituent.
    </p>
  </Section>
</Base>
