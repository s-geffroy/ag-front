---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import { offers } from '../lib/site';
---

<Base
  title="Offres"
  description="Basic informe. Standard surveille. Premium aide à arbitrer. Trois offres pour transformer l’analyse des corridors en décisions."
>
  <Section class="py-14">
    <h1 class="text-3xl">Offres</h1>
    <p class="mt-3 max-w-prose text-lg text-muted">
      Basic informe. Standard surveille. Premium aide à arbitrer.
    </p>

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        offers.map((o) => (
          <div
            class={`flex flex-col rounded-xl border p-6 ${o.featured ? 'border-accent/50 shadow-sm' : 'border-line'} bg-surface`}
          >
            <div class="flex items-baseline justify-between">
              <h2 class="font-serif text-2xl">{o.name}</h2>
              <span class="label">{o.promise}</span>
            </div>
            <p class="mt-2 text-sm text-muted">{o.tagline}</p>
            <p class="mt-4 text-lg font-semibold text-ink">{o.price}</p>

            <ul class="mt-5 space-y-1.5 text-sm">
              {o.includes.map((inc) => (
                <li class="flex gap-2">
                  <span class="text-status-on_track">✓</span>
                  <span class={inc.endsWith(':') ? 'font-medium text-ink' : 'text-ink/90'}>{inc}</span>
                </li>
              ))}
              {o.excludes.map((exc) => (
                <li class="flex gap-2 text-muted">
                  <span class="text-status-blocked">✗</span>
                  <span>{exc}</span>
                </li>
              ))}
            </ul>

            <a
              href={o.cta.href}
              class={`mt-6 rounded-md px-4 py-2.5 text-center text-sm font-medium ${o.featured ? 'bg-accent text-white hover:bg-accent/90' : 'border border-line hover:border-accent/40'}`}
            >
              {o.cta.label}
            </a>
          </div>
        ))
      }
    </div>

    <p class="mt-8 max-w-prose text-sm text-muted">
      Plafonds du pilote Premium : 1 corridor principal, 1 comparatif optionnel, 2–3 flux, 3–5 signaux
      suivis, 1 restitution. Au lancement, les offres Basic et Standard ouvrent progressivement à mesure
      que l’Atlas et l’historique se constituent.
    </p>
  </Section>
</Base>
