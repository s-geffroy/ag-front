---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Section from '../../components/Section.astro';
import Pill from '../../components/Pill.astro';
import Sources from '../../components/Sources.astro';
import { accessLabel, accessTone, confidenceLabel, formatDate } from '../../lib/labels';

export async function getStaticPaths() {
  const dossiers = await getCollection('dossiers');
  return dossiers.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<'dossiers'>;
}
const { entry } = Astro.props;
const d = entry.data;
const { Content } = await entry.render();
---

<Base title={d.title} description={d.summary} type="article">
  <Section width="prose" class="py-12">
    <a href="/dossiers" class="font-mono text-[11px] uppercase tracking-[0.1em] text-muted hover:text-accent">
      ← Dossiers
    </a>
    <div class="mt-5 flex flex-wrap items-center gap-2">
      <Pill tone="neutral">Dossier</Pill>
      <Pill tone={accessTone[d.access]}>{accessLabel[d.access]}</Pill>
    </div>
    <h1 class="mt-5 font-serif text-title font-bold">{d.title}</h1>
    <p class="verdict mt-5">{d.strategic_question}</p>
    <p class="mt-4 font-mono text-[11px] uppercase tracking-[0.08em] text-muted">
      {formatDate(d.date)} · {confidenceLabel[d.confidence]}
    </p>

    <article class="prose-ag mt-8"><Content /></article>

    <div class="mt-10 border-l-2 border-accent bg-accent/[0.05] p-5">
      <div class="eyebrow mb-1">Dossier complet</div>
      <p class="text-sm text-muted">
        La version complète (15–25 pages) est réservée aux offres payantes.
        <a href="/contact" class="text-accent underline underline-offset-2">Demander l’accès</a>.
      </p>
    </div>

    <Sources sources={d.sources} />
  </Section>
</Base>
