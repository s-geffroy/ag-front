---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Section from '../../components/Section.astro';
import Sources from '../../components/Sources.astro';
import { confidenceLabel, formatDate } from '../../lib/labels';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<'notes'>;
}
const { entry } = Astro.props;
const d = entry.data;
const { Content } = await entry.render();
---

<Base title={d.title} description={d.summary} type="article">
  <Section width="prose" class="py-12">
    <a href="/notes" class="text-sm text-accent hover:underline">← Notes</a>
    <h1 class="mt-4 text-3xl">{d.title}</h1>
    <div class="mt-2 text-xs text-muted">{formatDate(d.date)} · {confidenceLabel[d.confidence]}</div>

    <article class="prose-ag mt-8"><Content /></article>

    {
      d.signals.length ? (
        <section class="mt-8 rounded-lg border border-line bg-white p-5">
          <div class="label mb-2">Signaux à suivre</div>
          <ul class="list-disc space-y-1 pl-5 text-sm text-ink/90">
            {d.signals.map((s) => (
              <li>{s}</li>
            ))}
          </ul>
        </section>
      ) : null
    }

    {
      d.decision_implication ? (
        <p class="mt-6 text-sm">
          <span class="label">Implication décisionnelle — </span>
          {d.decision_implication}
        </p>
      ) : null
    }
    {
      d.blind_spot ? (
        <p class="mt-3 text-sm text-muted">
          <span class="label">Angle mort — </span>
          {d.blind_spot}
        </p>
      ) : null
    }

    <Sources sources={d.sources} />
  </Section>
</Base>
