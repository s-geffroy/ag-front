# Chokepoints Read API — consumer runtime env (copy to .env; never commit the real token).
# Consumed at RUNTIME when calling data endpoints. sync_contract.sh only needs API_BASE
# (the /openapi.json contract is served tokenless to any tailnet peer).
#
#   cp .env.example .env   &&   edit .env   (or: printf 'CHOKEPOINTS_TOKEN=%s\n' "$CHOKEPOINTS_TOKEN" >> .env)
# Inject at call time with:  docker run --env-file scripts/consumer/.env ...
# .env is gitignored (root .gitignore, line "\.env"); .env.example IS committed.

# Base URL of the read API on the tailnet.
API_BASE=https://srv1305127.tail880531.ts.net/api

# Bearer token issued producer-side (scope read, or read_tainted for restricted data).
# NEVER commit the real value. Leave blank here; put it only in .env.
CHOKEPOINTS_TOKEN=

# Slack Incoming Webhook — check_client.sh POSTs a drift alert here (empty = no Slack, silent).
# Create one at https://api.slack.com/messaging/webhooks ; the URL IS a secret → .env only.
SLACK_WEBHOOK_URL=
