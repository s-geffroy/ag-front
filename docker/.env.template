# =============================================================================
# docker/.env.template — canonical configuration template (version-controlled).
#
# Copy to docker/.env and fill in real values. docker/.env is git-ignored and is
# the file actually read by `docker compose` (variable interpolation + the hdde
# service env). NEVER commit real secrets — only this template is tracked.
#
#   cp docker/.env.template docker/.env   &&   edit docker/.env
# =============================================================================

# --- Host user (file ownership inside the mounted workspace) ---
# Find yours with: id -u  /  id -g
UID=1000
GID=1000

# --- Public site / Caddy ---
# Public IPv4 the `public` (Caddy) service binds to — bind the public IP, not 0.0.0.0,
# to avoid colliding with the cockpit's tailscale serve on the Tailscale interface.
# www.applied-geopolitics.com AND hdde.applied-geopolitics.com both resolve here (A records).
PUBLIC_IP=72.61.101.1

# --- Chokepoints Read API (Tailscale) ---
# The VPS reaches it over the tailnet. Tokens are NEVER shipped to any browser.
CHOKEPOINTS_API_URL=https://srv1305127.tail880531.ts.net/api
# READ scope (clear data). Used by: public site build AND HDDE enrichment (interview + red team).
CHOKEPOINTS_API_TOKEN=
# READ_TAINTED scope. Used ONLY by the internal cockpit (Tailscale). Restricted records stay
# internal, never published publicly and never used by HDDE (ADR 0013 / 0035).
CHOKEPOINTS_API_TOKEN_TAINTED=

# --- HDDE — hdde.applied-geopolitics.com (ADR 0032/0033/0034/0035) ---
# Session signing/owning secret. Generate: openssl rand -hex 32
HDDE_SESSION_SECRET=
# OpenAI red team. Set the key + flip to true to enable; false → offline facade (no cost).
HDDE_LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Optional price override (USD per 1M tokens) for cost tracking; defaults to the built-in gpt-4o price.
# OPENAI_PRICE_INPUT=2.50
# OPENAI_PRICE_OUTPUT=10.00

# --- Cockpit — editorial contradiction / red team (ADR 0039) ---
# Tailnet-only internal cockpit. Reuses OPENAI_API_KEY + OPENAI_MODEL above (server-side only, never
# shipped to the browser). Opt-in: false (or an empty OPENAI_API_KEY) → clearly-labelled offline
# facade, no API cost. Flip to true once the key is set to run real contradiction passes.
COCKPIT_LLM_ENABLED=false
