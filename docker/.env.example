# Copy to docker/.env and adjust if your host user is not 1000:1000.
# Find yours with: id -u  /  id -g
UID=1000
GID=1000

# Public IPv4 the `public` (Caddy) service binds to — bind the public IP, not 0.0.0.0,
# to avoid colliding with the cockpit's tailscale serve on the Tailscale interface.
PUBLIC_IP=72.61.101.1

# Chokepoints Read API (Tailscale). The VPS reaches it over the tailnet.
CHOKEPOINTS_API_URL=https://srv1305127.tail880531.ts.net/api
# READ scope (clear data) — used by the PUBLIC site build (apps/public). Never tainted.
CHOKEPOINTS_API_TOKEN=
# READ_TAINTED scope — used ONLY by the internal cockpit (Tailscale). Restricted records stay internal,
# never published to the public site (ADR 0013).
CHOKEPOINTS_API_TOKEN_TAINTED=

# --- HDDE (hdde.applied-geopolitics.com) — ADR 0032/0033/0034/0035 ---
# Long random string owning sessions. Generate: openssl rand -hex 32
HDDE_SESSION_SECRET=
# OpenAI red team. Leave disabled (offline facade) until you set a key.
HDDE_LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# HDDE reuses CHOKEPOINTS_API_TOKEN above (READ scope only — never the tainted token) to feed the
# interview + red team server-side. Public clients never see the token or tainted records (ADR 0035).
