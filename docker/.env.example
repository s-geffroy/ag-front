# Copy to docker/.env and adjust if your host user is not 1000:1000.
# Find yours with: id -u  /  id -g
UID=1000
GID=1000

# Public IPv4 the `public` (Caddy) service binds to — bind the public IP, not 0.0.0.0,
# to avoid colliding with the cockpit's tailscale serve on the Tailscale interface.
PUBLIC_IP=72.61.101.1
