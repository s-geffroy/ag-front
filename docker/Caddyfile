# Public site www.applied-geopolitics.com — automatic HTTPS (Let's Encrypt).
# Caddy obtains + renews certs once DNS points at this server (ADR 0010).
{
	email contact@applied-geopolitics.com
}

# Canonical host: static Astro build + same-origin lead endpoint.
www.applied-geopolitics.com {
	encode zstd gzip
	root * /srv

	# Long-cache hashed assets; HTML stays fresh.
	@assets path /_astro/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Public lead endpoint → self-hosted lead service (ADR 0006 / 0011).
	handle /api/* {
		reverse_proxy lead:8080
	}

	# Everything else: the static site.
	handle {
		file_server
	}

	handle_errors {
		rewrite * /404.html
		file_server
	}
}

# Apex → www (single canonical origin for SEO).
applied-geopolitics.com {
	redir https://www.applied-geopolitics.com{uri} permanent
}

# Hidden Dependency Discovery Engine — private, behind app auth (ADR 0033). Public DNS + HTTPS, but
# every /api route requires a session cookie; the SPA itself carries no secrets. Not for SEO.
hdde.applied-geopolitics.com {
	encode zstd gzip
	root * /srv-hdde

	header {
		# Keep it out of search indexes + add transport hardening (cookies are Secure/HttpOnly server-side).
		X-Robots-Tag "noindex, nofollow"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}

	# Internal ingestion API (ADR 0042) is for the VERDICT service ONLY, over the Docker network.
	# Never reachable from the public internet — 404 here (defense in depth on top of the service
	# token). Must precede the broader /api/* matcher.
	handle /api/internal/* {
		respond 404
	}

	# Authenticated API → hdde service (session enforced in-app).
	handle /api/* {
		reverse_proxy hdde:8090
	}

	# SPA: long-cache hashed assets, fall back to index.html for client routes.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"
	handle {
		try_files {path} /index.html
		file_server
	}
}

# VERDICT — Premium strategic decision-arbitrage cockpit, private behind app auth (ADR 0041). Public
# DNS + HTTPS, but every /api route requires a session cookie; the SPA carries no secrets. Not for SEO.
verdict.applied-geopolitics.com {
	encode zstd gzip
	root * /srv-verdict

	header {
		X-Robots-Tag "noindex, nofollow"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}

	# Authenticated API → verdict service (session enforced in-app).
	handle /api/* {
		reverse_proxy verdict:8095
	}

	# SPA: long-cache hashed assets, fall back to index.html for client routes.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"
	handle {
		try_files {path} /index.html
		file_server
	}
}
