# Dependencies
node_modules/

# Build outputs
dist/
build/
.astro/
*.tsbuildinfo
coverage/

# Tooling caches (agent-browser Chromium, etc.)
.cache/

# Lead ledger (runtime, may contain personal data)
apps/lead-api/data/*.ndjson

# Acquisition contacts: runtime state (receives visitor PII via the lead-api). Tracked seed is
# contacts.seed.json; the live file is git-ignored and materialised from the seed on first run.
apps/cockpit/data/contacts.json

# Editorial contradiction reports (ADR 0039): LLM-derived candidates, regenerated on demand. Tracked
# seed is contradictions.seed.json; the live file is git-ignored and materialised from it on first run.
apps/cockpit/data/contradictions.json

# LLM judge / pré-validation reports (ADR 0068): per-gate CANDIDATE verdicts, regenerated on demand.
# Tracked seed is judgements.seed.json; the live file is git-ignored. NB: validation_journal.json is
# the append-only human-validation audit trail (ADR 0046) and IS tracked — do not ignore it.
apps/cockpit/data/judgements.json

# One-click publish runtime markers (ADR 0069): the cockpit touches `.publish-pending`, the host
# rebuild watcher writes `.last-build`. Host state, never tracked.
apps/public/.publish-pending
apps/public/.last-build

# Host rebuild-watcher log (scripts/redeploy-public.sh --if-pending).
scripts/redeploy-public.log

# Source deposits: uploaded evidence files (binary, possibly paywalled/confidential) + their index.
# Never tracked; the dir is created at runtime by the cockpit server.
apps/cockpit/data/uploads/
apps/cockpit/data/uploads.json

# HDDE runtime: SQLite DB (confidential client cases) + rendered exports. Never tracked.
apps/hdde-api/data/*.sqlite
apps/hdde-api/data/*.sqlite-*
apps/hdde-api/data/exports/*
!apps/hdde-api/data/.gitkeep
!apps/hdde-api/data/exports/.gitkeep

# VERDICT runtime: SQLite DB (confidential client decisions) + rendered exports. Never tracked.
apps/verdict-api/data/*.sqlite
apps/verdict-api/data/*.sqlite-*
apps/verdict-api/data/exports/*
!apps/verdict-api/data/.gitkeep
!apps/verdict-api/data/exports/.gitkeep

# Env (keep examples + templates; real .env stays out)
.env
.env.*
!.env.example
!.env.template

# Editor / OS
.DS_Store
*.log

# Red-team injection regression cron log (ADR 0063)
scripts/redteam-injection.log
